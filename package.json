{
  "name": "quietcv",
  "version": "1.0.0",
  "private": true,
  "description": "A quiet, AI-native Markdown resume workbench with A4 paginated preview and PDF export.",
  "scripts": {
    "copy-monaco": "node scripts/copy-monaco.mjs",
    "predev": "node scripts/copy-monaco.mjs",
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "prebuild": "node scripts/copy-monaco.mjs",
    "build": "next build",
    "check": "pnpm typecheck && pnpm build",
    "start": "next start",
    "preview": "node scripts/copy-monaco.mjs && opennextjs-cloudflare build && node scripts/patch-open-next-worker.mjs && opennextjs-cloudflare preview",
    "deploy": "node scripts/copy-monaco.mjs && opennextjs-cloudflare build && node scripts/patch-open-next-worker.mjs && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.564.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^2.1.9",
    "react-to-print": "^3.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "1.3.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "5.7.3",
    "wrangler": "^4.99.0"
  }
}
